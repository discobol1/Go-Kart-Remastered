{
  "name": "go-kart-remastered",
  "version": "1.1.0",
  "private": true,
  "description": "Local race server for Go-Kart Remastered timing system",
  "scripts": {
    "start": "node server.js",
    "start:host": "node scripts/launch.js",
    "launch": "node scripts/launch.js",
    "build": "node scripts/build-release.js",
    "build:standalone": "node scripts/build-standalone.js",
    "build:win": "node scripts/build-release.js --platform=win32 && node scripts/build-standalone.js --platform=win32",
    "test": "node scripts/debug-suite.js"
  },
  "dependencies": {
    "express": "^4.21.2",
    "ws": "^8.18.0"
  }
}
